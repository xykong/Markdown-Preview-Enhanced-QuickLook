<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Temporarily disable App Sandbox for image loading -->
    <!-- TODO: Re-enable sandbox with proper file access configuration -->
    <!--
    <key>com.apple.security.app-sandbox</key>
    <true/>
    -->

    <!-- Allow read-only access to user-selected files (e.g. Markdown documents) -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>

    <!-- Allow attaching debugger in Debug builds -->
    <key>com.apple.security.get-task-allow</key>
    <true/>

    <!-- Allow network access for WebView -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow JIT (Recommended for WebView performance/stability) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow printing (WebView often tries to access print services) -->
    <key>com.apple.security.print</key>
    <true/>

    <!-- Allow access to downloads (Sparkle needs read-write for installing updates) -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>

    <!-- Sparkle Installer Support -->
    <!-- Allow Sparkle XPC services communication (required for sandboxed apps) -->
    <key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
    <array>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER)-spks</string>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER)-spki</string>
    </array>

    <!-- Allow Sparkle to write to /Applications for update installation -->
    <key>com.apple.security.temporary-exception.files.absolute-path.read-write</key>
    <array>
        <string>/Applications</string>
    </array>

    <!-- App Groups removed: macOS 26 (Tahoe) rejects App Group containers for ad-hoc signed apps.
         Settings are now shared via a plist file in ~/Library/Application Support/FluxMarkdown/.
         See: https://github.com/xykong/flux-markdown/issues/13 -->
</dict>
</plist>

